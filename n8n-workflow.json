{
  "name": "SeerooTravels AI Travel & Visa Automation",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "whatsapp/webhook",
        "options": {}
      },
      "id": "webhook-trigger-id",
      "name": "WhatsApp Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        100,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.body.entry[0].changes[0].value.messages[0].type }}",
              "value2": "text"
            },
            {
              "value1": "={{ $json.body.entry[0].changes[0].value.messages[0].type }}",
              "value2": "image"
            },
            {
              "value1": "={{ $json.body.entry[0].changes[0].value.messages[0].type }}",
              "value2": "document"
            }
          ]
        },
        "combineOperation": "any"
      },
      "id": "check-msg-type-id",
      "name": "Check Message Type",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        280,
        300
      ]
    },
    {
      "parameters": {
        "keepOnlySet": true,
        "values": {
          "string": [
            {
              "name": "phone",
              "value": "={{ $json.body.entry[0].changes[0].value.messages[0].from }}"
            },
            {
              "name": "message",
              "value": "={{ $json.body.entry[0].changes[0].value.messages[0].text ? $json.body.entry[0].changes[0].value.messages[0].text.body : 'Attachment Uploaded' }}"
            },
            {
              "name": "senderName",
              "value": "={{ $json.body.entry[0].changes[0].value.contacts[0].profile.name }}"
            },
            {
              "name": "msgType",
              "value": "={{ $json.body.entry[0].changes[0].value.messages[0].type }}"
            },
            {
              "name": "mediaId",
              "value": "={{ $json.body.entry[0].changes[0].value.messages[0].image ? $json.body.entry[0].changes[0].value.messages[0].image.id : ($json.body.entry[0].changes[0].value.messages[0].document ? $json.body.entry[0].changes[0].value.messages[0].document.id : '') }}"
            },
            {
              "name": "mediaHash",
              "value": "={{ $json.body.entry[0].changes[0].value.messages[0].image ? $json.body.entry[0].changes[0].value.messages[0].image.sha256 : ($json.body.entry[0].changes[0].value.messages[0].document ? $json.body.entry[0].changes[0].value.messages[0].document.sha256 : '') }}"
            }
          ]
        },
        "options": {}
      },
      "id": "parse-message-fields-id",
      "name": "Parse Details",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [
        480,
        300
      ]
    },
    {
      "parameters": {
        "options": {
          "systemMessage": "You are the AI Travel & Visa Processing Agent for SeerooTravels (Tagline: \"Explore Beyond Boundaries\") connected via WhatsApp.\nYour tone is helpful, friendly, and structured. Use bold (*text*) for emphasis.\n\nYou guide users through their application status journey:\n1. NEW_USER: Welcome them, query the registration tool to generate USR ID, and request passport/documents.\n2. AWAITING_DOCUMENTS: Ask them to upload their documents. If they uploaded an attachment, trigger the Document Processing tool with the details.\n3. DOCUMENTS_PROCESSING: Llama OCR extracts metadata. If confidence is low, escalate to human review. Else, update to PAYMENT_PENDING.\n4. PAYMENT_PENDING: Request payment of invoice. If they provide a reference code, trigger the Payment Proof tool to log reference and generate ticket.\n5. HUMAN_REVIEW: Inform them their case is undergoing final manual verification.\n6. VISA_STATUS_AVAILABLE: Confirm if approved/rejected.\n\nUse your tools to query database state, register users, check/process documents, register payments, and add audit logs."
        }
      },
      "id": "ai-agent-id",
      "name": "SeerooTravels AI Agent",
      "type": "n8n-nodes-langchain.agent",
      "typeVersion": 1,
      "position": [
        720,
        300
      ]
    },
    {
      "parameters": {
        "model": "llama-3.1-70b-versatile",
        "options": {
          "temperature": 0.5
        }
      },
      "id": "groq-model-id",
      "name": "Groq Llama 3 Chat Model",
      "type": "n8n-nodes-langchain.lmChatGroq",
      "typeVersion": 1,
      "position": [
        600,
        480
      ],
      "credentials": {
        "groqApi": {
          "id": "your-groq-api-key-credential-id"
        }
      }
    },
    {
      "parameters": {
        "contextKey": "chat_history",
        "sessionKey": "={{ $('Parse Details').item.json.phone }}"
      },
      "id": "window-memory-id",
      "name": "Window Memory",
      "type": "n8n-nodes-langchain.memoryBufferWindow",
      "typeVersion": 1,
      "position": [
        720,
        480
      ]
    },
    {
      "parameters": {
        "name": "CheckUserStatus",
        "description": "Checks the current registration status, visa details, lead_status, active flags, and ticket ID for a user. Input should be the phone number.",
        "jsCode": "const response = await fetch(\"YOUR_APPS_SCRIPT_WEB_APP_URL?action=getSettings\"); // retrieves settings\n// In production, query users sheet row matching user's phone\nreturn JSON.stringify({ exists: true, user_id: \"USR-2026-0001\", status: \"AWAITING_DOCUMENTS\", is_active: \"TRUE\", lead_status: \"active\" });"
      },
      "id": "tool-check-user-id",
      "name": "Check User Status Tool",
      "type": "n8n-nodes-langchain.toolCode",
      "typeVersion": 1,
      "position": [
        900,
        480
      ]
    },
    {
      "parameters": {
        "name": "RegisterUser",
        "description": "Registers a new user in the database. Generates next sequential USR-YYYY-XXXX ID. Inputs are name, phone, country, source.",
        "jsCode": "const idResponse = await fetch(\"YOUR_APPS_SCRIPT_WEB_APP_URL?action=generateId&prefix=USR&sheetName=users&colIndex=1\");\nconst idData = await idResponse.json();\n// In production, appends a row to users sheet via Apps Script API or GSheets node\nreturn JSON.stringify({ success: true, user_id: idData.id, message: \"User created successfully.\" });"
      },
      "id": "tool-register-user-id",
      "name": "Register User Tool",
      "type": "n8n-nodes-langchain.toolCode",
      "typeVersion": 1,
      "position": [
        1020,
        480
      ]
    },
    {
      "parameters": {
        "name": "ProcessUploadedDocument",
        "description": "Classifies the document type (Passport, CNIC, Visa Copy, Bank Statement, Passport Photo), checks duplicate file hashes, and runs Llama OCR extraction (Passport Number, Name, Nationality, DOB, Expiry Date). Inputs are: user_id, file_url, file_hash, file_name.",
        "jsCode": "const fileHash = input.file_hash || \"test-hash\";\n// Verify duplicates against sheet\n// Calls OCR extraction\nconst ocrConfidence = \"92%\";\nconst extractedData = { passport_number: \"EP123456\", full_name: \"John Doe\", nationality: \"Pakistani\", date_of_birth: \"1995-05-15\", expiry_date: \"2035-05-15\", ocr_confidence: ocrConfidence };\nreturn JSON.stringify({ success: true, classified_as: \"Passport\", data: extractedData, document_status: \"verified\" });"
      },
      "id": "tool-process-document-id",
      "name": "Document Processing Tool",
      "type": "n8n-nodes-langchain.toolCode",
      "typeVersion": 1,
      "position": [
        1140,
        480
      ]
    },
    {
      "parameters": {
        "name": "RegisterPaymentProof",
        "description": "Registers a payment reference number and generates a ticket ID (VISA-YYYY-XXXX or TOUR-YYYY-XXXX). Inputs are: user_id, amount, reference_number, payment_proof_url.",
        "jsCode": "const idResponse = await fetch(\"YOUR_APPS_SCRIPT_WEB_APP_URL?action=generateId&prefix=VISA&sheetName=tickets&colIndex=1\");\nconst idData = await idResponse.json();\nreturn JSON.stringify({ success: true, ticket_id: idData.id, message: \"Payment logged and ticket generated successfully.\" });"
      },
      "id": "tool-register-payment-id",
      "name": "Payment Proof Tool",
      "type": "n8n-nodes-langchain.toolCode",
      "typeVersion": 1,
      "position": [
        1260,
        480
      ]
    },
    {
      "parameters": {
        "name": "LogAuditAction",
        "description": "Logs an audit trail record in the database. Inputs are: user_id, action, details, performed_by (System | Agent | Admin | AI).",
        "jsCode": "return JSON.stringify({ success: true, message: \"Audit action logged successfully.\" });"
      },
      "id": "tool-log-audit-id",
      "name": "Log Audit Tool",
      "type": "n8n-nodes-langchain.toolCode",
      "typeVersion": 1,
      "position": [
        1380,
        480
      ]
    },
    {
      "parameters": {
        "operation": "append",
        "sheetId": "YOUR_SPREADSHEET_ID_HERE",
        "range": "user_messages!A:D",
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "user_id": "={{ $('ai-agent-id').item.json.output.includes('USR-') ? $('ai-agent-id').item.json.output.match(/USR-\\d{4}-\\d{4}/)[0] : 'USR-2026-0001' }}",
            "message": "={{ $('Parse Details').item.json.message }}",
            "message_type": "={{ $('Parse Details').item.json.msgType }}",
            "timestamp": "={{ new Date().toISOString() }}"
          }
        },
        "options": {}
      },
      "id": "gsheet-log-message-id",
      "name": "Log Chat to Sheets",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 3,
      "position": [
        920,
        300
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "your-google-oauth-credentials-id"
        }
      }
    },
    {
      "parameters": {
        "operation": "append",
        "sheetId": "YOUR_SPREADSHEET_ID_HERE",
        "range": "audit_logs!A:F",
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "log_id": "=LOG-{{ new Date().getFullYear() }}-{{ Math.floor(1000 + Math.random() * 9000) }}",
            "user_id": "={{ $('ai-agent-id').item.json.output.includes('USR-') ? $('ai-agent-id').item.json.output.match(/USR-\\d{4}-\\d{4}/)[0] : 'USR-2026-0001' }}",
            "action": "Chat Message Exchanged",
            "details": "=Incoming: {{ $('Parse Details').item.json.message }} | Outgoing: {{ $('ai-agent-id').item.json.output }}",
            "performed_by": "System",
            "timestamp": "={{ new Date().toISOString() }}"
          }
        },
        "options": {}
      },
      "id": "gsheet-log-audit-node-id",
      "name": "Write Audit Log",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 3,
      "position": [
        1100,
        300
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "your-google-oauth-credentials-id"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://graph.facebook.com/v17.0/YOUR_PHONE_NUMBER_ID/messages",
        "authentication": "predefined",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer YOUR_WHATSAPP_SYSTEM_ACCESS_TOKEN"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "bodyParameters": {
          "parameters": [
            {
              "name": "messaging_product",
              "value": "whatsapp"
            },
            {
              "name": "recipient_type",
              "value": "individual"
            },
            {
              "name": "to",
              "value": "={{ $('Parse Details').item.json.phone }}"
            },
            {
              "name": "type",
              "value": "text"
            },
            {
              "name": "text.body",
              "value": "={{ $('ai-agent-id').item.json.output }}"
            }
          ]
        },
        "options": {}
      },
      "id": "whatsapp-send-msg-id",
      "name": "Send WhatsApp Reply",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1300,
        300
      ]
    }
  ],
